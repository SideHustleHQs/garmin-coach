# Supabase Postgres connection string
# From: Supabase dashboard → Settings → Database → URI
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Garmin Connect credentials (used by sync script)
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword

# Athlete ID used in ingest.py
ATHLETE_ID=vriendin

# Set automatically by Vercel — no manual config needed
# VERCEL_URL=garmin-coach-xxx.vercel.app

# Set manually if using a custom domain
# FRONTEND_URL=https://yourdomain.com
