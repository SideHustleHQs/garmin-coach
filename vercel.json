{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "dashboard/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/main.py" },
    { "src": "/(.*\\..*)", "dest": "/dashboard/dist/$1" },
    { "src": "/(.*)", "dest": "/dashboard/dist/index.html" }
  ]
}
